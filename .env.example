# Application
APP_NAME=MAM
APP_VERSION=1.0.0
DEBUG=false

# Database
DATABASE_URL=postgresql://mam_user:mam_password@localhost:5432/mam_db

# Security
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000
